<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Panneaux solaires en PACA - Installation en 48h, garantie 25 ans. Économisez jusqu'à 1200€/an. Devis gratuit en 24h.">
    <meta name="keywords" content="panneaux solaires PACA, installation photovoltaïque, énergie solaire 13 30 83 84, devis gratuit">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <link rel="apple-touch-icon" href="favicon.svg">

    <!-- Open Graph -->
    <meta property="og:title" content="Énergie Solaire France - Panneaux Solaires PACA">
    <meta property="og:description" content="Installation en 48h • Garantie 25 ans • Financement 0€ • Spécialiste PACA">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://devis-solaire-paca.fr">

    <title>Énergie Solaire France - Panneaux Solaires PACA | Devis Gratuit 24h</title>

    <!-- Facebook Pixel Code -->
    <script>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '873087782355274');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=873087782355274&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Facebook Pixel Code -->

    <!-- Google tag (gtag.js) - Google Ads -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17787585422"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-17787585422');
      gtag('config', 'G-2VZDLVFWCR');
    </script>
    <!-- End Google Ads Tag -->

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #1e3a8a;
            --primary-light: #3b82f6;
            --secondary: #fbbf24;
            --secondary-dark: #f59e0b;
            --dark: #1f2937;
            --light: #f3f4f6;
            --success: #10b981;
            --success-dark: #059669;
        }

        /* Smooth scroll */
        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            color: var(--dark);
            overflow-x: hidden;
        }

        /* Logo Header */
        .logo-header {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            padding: 20px;
            box-shadow: 0 2px 20px rgba(0,0,0,0.08);
            position: sticky;
            top: 0;
            z-index: 100;
            transition: all 0.3s ease;
        }

        .logo-header.scrolled {
            padding: 15px;
            box-shadow: 0 4px 30px rgba(0,0,0,0.15);
        }

        .logo-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .logo-container img {
            height: 50px;
            width: auto;
            transition: all 0.3s ease;
        }

        .logo-header.scrolled .logo-container img {
            height: 40px;
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: white;
            padding: 80px 20px 60px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '☀️';
            position: absolute;
            font-size: 400px;
            opacity: 0.08;
            top: -100px;
            right: -100px;
            animation: rotate 20s linear infinite;
        }

        .hero::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 100px;
            background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.1));
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 20px;
            line-height: 1.2;
            animation: fadeInUp 0.8s ease-out;
            text-shadow: 2px 4px 8px rgba(0,0,0,0.2);
        }

        .hero .highlight {
            color: var(--secondary);
            font-size: 3rem;
            background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-dark) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 1.3rem;
            margin-bottom: 15px;
            opacity: 0.95;
            animation: fadeInUp 0.8s ease-out 0.2s both;
        }

        .benefits {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
            margin: 30px 0;
            animation: fadeInUp 0.8s ease-out 0.4s both;
        }

        .benefit {
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(15px);
            padding: 12px 24px;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 600;
            border: 1px solid rgba(255,255,255,0.3);
            transition: all 0.3s ease;
        }

        .benefit:hover {
            background: rgba(255,255,255,0.3);
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

        /* Form Section */
        .form-section {
            background: white;
            max-width: 600px;
            margin: -40px auto 0;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 20px 80px rgba(0,0,0,0.2);
            position: relative;
            z-index: 10;
            animation: fadeInUp 1s ease-out 0.6s both;
            border: 1px solid rgba(30,58,138,0.1);
        }

        .form-section h2 {
            text-align: center;
            color: var(--primary);
            margin-bottom: 10px;
            font-size: 1.8rem;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .form-section .subtitle {
            text-align: center;
            color: #6b7280;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--dark);
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 15px;
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            font-size: 16px; /* 16px minimum pour éviter zoom iOS */
            transition: all 0.3s;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }

        .cta-button {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, var(--success) 0%, var(--success-dark) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1.2rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
            position: relative;
            overflow: hidden;
        }

        .cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .cta-button:hover::before {
            left: 100%;
        }

        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(16, 185, 129, 0.4);
        }

        .cta-button:active {
            transform: translateY(-1px);
        }

        .trust-badges {
            display: flex;
            justify-content: space-around;
            margin-top: 25px;
            padding-top: 25px;
            border-top: 1px solid #e5e7eb;
        }

        .badge {
            text-align: center;
            font-size: 0.85rem;
            color: #6b7280;
        }

        .badge strong {
            display: block;
            color: var(--primary);
            font-size: 1.5rem;
            margin-bottom: 5px;
        }

        /* Features Section */
        .features {
            padding: 80px 20px;
            background: var(--light);
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 2.2rem;
            color: var(--primary);
            margin-bottom: 50px;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .feature-card {
            background: white;
            padding: 35px;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            text-align: center;
            transition: all 0.4s ease;
            border: 1px solid transparent;
        }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(30,58,138,0.15);
            border-color: rgba(30,58,138,0.1);
        }

        .feature-card .icon {
            font-size: 3rem;
            margin-bottom: 20px;
        }

        .feature-card h3 {
            color: var(--primary);
            margin-bottom: 15px;
            font-size: 1.4rem;
        }

        .feature-card p {
            color: #6b7280;
            line-height: 1.7;
        }

        /* Process Section */
        .process {
            padding: 80px 20px;
            background: white;
        }

        .process-steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 40px;
            margin-top: 50px;
        }

        .step {
            text-align: center;
            position: relative;
        }

        .step-number {
            width: 60px;
            height: 60px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0 auto 20px;
        }

        .step h3 {
            color: var(--dark);
            margin-bottom: 10px;
            font-size: 1.3rem;
        }

        .step p {
            color: #6b7280;
        }

        /* Testimonials */
        .testimonials {
            padding: 80px 20px;
            background: var(--light);
        }

        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 50px;
        }

        .testimonial {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        }

        .testimonial-text {
            font-style: italic;
            color: #4b5563;
            margin-bottom: 20px;
            line-height: 1.7;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .author-info strong {
            display: block;
            color: var(--dark);
        }

        .author-info span {
            color: #6b7280;
            font-size: 0.9rem;
        }

        .stars {
            color: var(--secondary);
            margin-top: 5px;
        }

        /* FAQ */
        .faq {
            padding: 80px 20px;
            background: white;
        }

        .faq-list {
            max-width: 800px;
            margin: 50px auto 0;
        }

        .faq-item {
            background: var(--light);
            padding: 25px;
            border-radius: 10px;
            margin-bottom: 15px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .faq-item:hover {
            background: #e5e7eb;
        }

        .faq-question {
            font-weight: 600;
            color: var(--primary);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .faq-answer {
            color: #4b5563;
            margin-top: 15px;
            line-height: 1.7;
            display: none;
        }

        .faq-item.active .faq-answer {
            display: block;
        }

        /* CTA Final */
        .final-cta {
            padding: 80px 20px;
            background: linear-gradient(135deg, var(--primary) 0%, #2563eb 100%);
            color: white;
            text-align: center;
        }

        .final-cta h2 {
            font-size: 2.5rem;
            margin-bottom: 20px;
        }

        .final-cta p {
            font-size: 1.3rem;
            margin-bottom: 30px;
            opacity: 0.95;
        }

        .final-cta .cta-button {
            max-width: 400px;
            margin: 0 auto;
        }

        /* Footer */
        footer {
            background: var(--dark);
            color: white;
            padding: 40px 20px;
            text-align: center;
        }

        footer a {
            color: var(--secondary);
            text-decoration: none;
        }

        /* Bouton sticky mobile */
        .sticky-cta-mobile {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--success);
            color: white;
            padding: 15px 20px;
            text-align: center;
            font-weight: 700;
            font-size: 1.1rem;
            border: none;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
            z-index: 999;
            cursor: pointer;
        }

        @media (max-width: 768px) {
            .sticky-cta-mobile {
                display: block;
            }
        }

        /* Success Message */
        .success-message {
            display: none;
            background: var(--success);
            color: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            margin-top: 20px;
            font-weight: 600;
        }

        .success-message.show {
            display: block;
            animation: slideIn 0.5s;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Tablette Landscape */
        @media (max-width: 1024px) and (min-width: 769px) {
            .hero h1 {
                font-size: 2.2rem;
            }

            .hero .highlight {
                font-size: 2.8rem;
            }
        }

        /* Tablette Portrait */
        @media (max-width: 768px) {
            .hero h1 {
                font-size: 1.8rem;
            }

            .hero .highlight {
                font-size: 2.2rem;
            }

            .hero p {
                font-size: 1.1rem;
            }

            .form-section {
                margin: -20px 15px 0;
                padding: 30px 20px;
            }

            .section-title {
                font-size: 1.8rem;
            }

            .trust-badges {
                flex-direction: column;
                gap: 15px;
            }

            .hero::before {
                font-size: 250px; /* Emoji plus petit sur tablette */
            }
        }

        /* Très petit mobile */
        @media (max-width: 480px) {
            .hero h1 {
                font-size: 1.5rem;
            }

            .hero .highlight {
                font-size: 1.9rem;
            }

            .hero p {
                font-size: 1rem;
            }

            .benefit {
                font-size: 0.9rem;
                padding: 10px 18px;
            }

            .form-section {
                margin: -15px 10px 0;
                padding: 25px 15px;
            }

            .form-section h2 {
                font-size: 1.5rem;
            }

            .cta-button {
                padding: 16px;
                font-size: 1.1rem;
            }

            .hero::before {
                font-size: 180px; /* Emoji encore plus petit sur petit mobile */
            }

            .logo-container img {
                height: 40px;
            }

            .section-title {
                font-size: 1.5rem;
            }

            .feature-card,
            .testimonial {
                padding: 25px;
            }
        }
    </style>
</head>
<body>
    <!-- Logo Header -->
    <header class="logo-header">
        <div class="logo-container">
            <img src="logo.svg" alt="Énergie Solaire France - Panneaux Solaires PACA">
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <h1>
            Économisez <span class="highlight">1 200 €/an</span><br>
            avec des Panneaux Solaires
        </h1>
        <p>Installation dans le sud de la France  (13, 30, 83, 84)</p>

        <div class="benefits">
            <div class="benefit">⚡ Installation 48h</div>
            <div class="benefit">🛡️ Garantie 25 ans</div>
            <div class="benefit">💰 Financement 0€</div>
            <div class="benefit">📋 Aides & subventions</div>
        </div>
    </section>

    <!-- Form Section -->
    <div class="container">
        <div class="form-section">
            <h2>Devis Gratuit en 24h</h2>
            <p class="subtitle">Calculez vos économies personnalisées</p>

            <form id="devisForm">
                <div class="form-group">
                    <label for="nom">Nom complet *</label>
                    <input
                        type="text"
                        id="nom"
                        name="nom"
                        required
                        placeholder="Jean Dupont"
                        pattern="^[a-zA-ZÀ-ÿ\s\-']+$"
                        title="Lettres uniquement (pas de chiffres)"
                        minlength="2"
                    >
                </div>

                <div class="form-group">
                    <label for="email">Email *</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        required
                        placeholder="jean.dupont@example.com"
                        title="Email valide requis"
                    >
                </div>

                <div class="form-group">
                    <label for="telephone">Téléphone *</label>
                    <input
                        type="tel"
                        id="telephone"
                        name="telephone"
                        required
                        placeholder="06 12 34 56 78"
                        pattern="^0[1-9]([ ]?\d{2}){4}$"
                        title="Format: 06 12 34 56 78 (10 chiffres commençant par 0)"
                        inputmode="numeric"
                    >
                </div>

                <div class="form-group">
                    <label for="codePostal">Code postal PACA *</label>
                    <input
                        type="text"
                        id="codePostal"
                        name="codePostal"
                        required
                        placeholder="13001, 30000, 83000, 84000"
                        pattern="^(13|30|83|84)\d{3}$"
                        title="Code postal PACA uniquement (13, 30, 83, 84)"
                        maxlength="5"
                        inputmode="numeric"
                    >
                </div>

                <div class="form-group">
                    <label for="departement">Département</label>
                    <select id="departement" name="departement" required>
                        <option value="">Sélectionnez</option>
                        <option value="13">13 - Bouches-du-Rhône</option>
                        <option value="30">30 - Gard</option>
                        <option value="83">83 - Var</option>
                        <option value="84">84 - Vaucluse</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="proprietaire">Êtes-vous propriétaire d’une maison individuelle ? *</label>
                    <select id="proprietaire" name="proprietaire" required>
                        <option value="">-- Sélectionnez --</option>
                        <option value="oui">Oui, je suis propriétaire</option>
                        <option value="non">Non, je suis locataire</option>
                    </select>
                </div>

                <button type="submit" class="cta-button">
                    📞 Recevoir mon devis gratuit
                </button>

                <div class="success-message" id="successMessage">
                    ✅ Demande envoyée ! Nous vous contactons dans les 24h.
                </div>
            </form>

            <div class="trust-badges">
                <div class="badge">
                    <strong>500+</strong>
                    Installations
                </div>
                <div class="badge">
                    <strong>25 ans</strong>
                    Garantie
                </div>
                <div class="badge">
                    <strong>4.9/5</strong>
                    ⭐⭐⭐⭐⭐
                </div>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <section class="features">
        <div class="container">
            <h2 class="section-title">Pourquoi Choisir Énergie Solaire ?</h2>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="icon">⚡</div>
                    <h3>Installation Ultra-Rapide</h3>
                    <p>Vos panneaux solaires installés en seulement 48 heures. Équipe professionnelle et matériel de qualité.</p>
                </div>

                <div class="feature-card">
                    <div class="icon">💰</div>
                    <h3>Prix Concurrentiels</h3>
                    <p>Économisez jusqu'à 1 200€ par an sur vos factures d'électricité. Financement sans apport disponible.</p>
                </div>

                <div class="feature-card">
                    <div class="icon">🛡️</div>
                    <h3>Garantie 25 Ans</h3>
                    <p>Tranquillité d'esprit totale avec notre garantie constructeur de 25 ans sur tous nos panneaux.</p>
                </div>

                <div class="feature-card">
                    <div class="icon">📋</div>
                    <h3>Accompagnement Complet</h3>
                    <p>Nous gérons toutes les démarches administratives : aides, subventions, crédits d'impôt.</p>
                </div>

                <div class="feature-card">
                    <div class="icon">🔧</div>
                    <h3>SAV Réactif</h3>
                    <p>Service après-vente disponible 7j/7. Intervention rapide en cas de besoin.</p>
                </div>

                <div class="feature-card">
                    <div class="icon">🌍</div>
                    <h3>Local PACA</h3>
                    <p>Entreprise basée en PACA, spécialisée dans les départements 13, 30, 83 et 84.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Process Section -->
    <section class="process">
        <div class="container">
            <h2 class="section-title">Comment Ça Marche ?</h2>

            <div class="process-steps">
                <div class="step">
                    <div class="step-number">1</div>
                    <h3>Devis Gratuit</h3>
                    <p>Remplissez le formulaire. Nous vous contactons sous 24h pour une étude personnalisée.</p>
                </div>

                <div class="step">
                    <div class="step-number">2</div>
                    <h3>Visite Technique</h3>
                    <p>Un expert se déplace chez vous gratuitement pour analyser votre toiture et vos besoins.</p>
                </div>

                <div class="step">
                    <div class="step-number">3</div>
                    <h3>Installation</h3>
                    <p>Nos équipes installent vos panneaux en 48h. Matériel premium et installation certifiée.</p>
                </div>

                <div class="step">
                    <div class="step-number">4</div>
                    <h3>Économies !</h3>
                    <p>Profitez immédiatement de factures réduites et d'une énergie propre et renouvelable.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section class="testimonials">
        <div class="container">
            <h2 class="section-title">Ils Nous Font Confiance</h2>

            <div class="testimonials-grid">
                <div class="testimonial">
                    <p class="testimonial-text">
                        "Installation impeccable en 2 jours comme promis. Ma facture est passée de 180€ à 15€ par mois. Je recommande !"
                    </p>
                    <div class="testimonial-author">
                        <div class="author-info">
                            <strong>Jean D.</strong>
                            <span>Aix-en-Provence (13)</span>
                            <div class="stars">⭐⭐⭐⭐⭐</div>
                        </div>
                    </div>
                </div>

                <div class="testimonial">
                    <p class="testimonial-text">
                        "Équipe professionnelle et accompagnement parfait pour les subventions. Installation soignée, je suis ravi !"
                    </p>
                    <div class="testimonial-author">
                        <div class="author-info">
                            <strong>Marie L.</strong>
                            <span>Avignon (84)</span>
                            <div class="stars">⭐⭐⭐⭐⭐</div>
                        </div>
                    </div>
                </div>

                <div class="testimonial">
                    <p class="testimonial-text">
                        "Prix très compétitifs et garantie 25 ans rassurante. Pose rapide et propre. Excellent rapport qualité/prix !"
                    </p>
                    <div class="testimonial-author">
                        <div class="author-info">
                            <strong>Pierre M.</strong>
                            <span>Toulon (83)</span>
                            <div class="stars">⭐⭐⭐⭐⭐</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq">
        <div class="container">
            <h2 class="section-title">Questions Fréquentes</h2>

            <div class="faq-list">
                <div class="faq-item">
                    <div class="faq-question">
                        Combien puis-je économiser avec des panneaux solaires ?
                        <span>+</span>
                    </div>
                    <div class="faq-answer">
                        En moyenne, nos clients en PACA économisent entre 900€ et 1 500€ par an sur leurs factures d'électricité, selon la taille de l'installation et leur consommation.
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        Quelles aides sont disponibles en 2026 ?
                        <span>+</span>
                    </div>
                    <div class="faq-answer">
                        Plusieurs aides sont cumulables : MaPrimeRénov', prime à l'autoconsommation, TVA réduite à 10%, et exonération de taxe foncière dans certaines communes. Nous vous accompagnons dans toutes les démarches.
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        Combien de temps dure l'installation ?
                        <span>+</span>
                    </div>
                    <div class="faq-answer">
                        L'installation complète est réalisée en 48 heures maximum (2 jours ouvrés). Nos équipes sont formées et utilisent du matériel professionnel pour une pose rapide et soignée.
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        Quelle est la garantie sur les panneaux ?
                        <span>+</span>
                    </div>
                    <div class="faq-answer">
                        Tous nos panneaux solaires bénéficient d'une garantie constructeur de 25 ans sur le rendement et 10 ans sur l'onduleur. De plus, notre installation est garantie 2 ans.
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        Le financement sans apport est-il vraiment possible ?
                        <span>+</span>
                    </div>
                    <div class="faq-answer">
                        Oui ! Nous travaillons avec plusieurs partenaires financiers qui proposent des solutions de financement à 0€ d'apport, avec des mensualités adaptées à votre budget.
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        Mon toit est-il adapté ?
                        <span>+</span>
                    </div>
                    <div class="faq-answer">
                        La plupart des toits sont compatibles. Lors de la visite technique gratuite, notre expert analysera l'orientation, l'inclinaison, et la structure de votre toiture pour vous proposer la solution optimale.
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta">
        <div class="container">
            <h2>Prêt à Passer à l'Énergie Solaire ?</h2>
            <p>Demandez votre devis gratuit en 2 minutes</p>
            <button class="cta-button" onclick="document.getElementById('devisForm').scrollIntoView({behavior: 'smooth'})">
                📞 Je veux mon devis gratuit
            </button>
        </div>
    </section>

    <!-- Sticky CTA Mobile -->
    <button class="sticky-cta-mobile" onclick="document.getElementById('devisForm').scrollIntoView({behavior: 'smooth'})">
        📞 Devis Gratuit en 24h
    </button>

    <!-- Footer -->
    <footer>
        <div class="container">
            <p>&copy; 2026 Énergie Solaire France - Tous droits réservés</p>
            <p>Installation panneaux solaires PACA : 13 (Bouches-du-Rhône) • 30 (Gard) • 83 (Var) • 84 (Vaucluse)</p>
            <p style="margin-top: 10px; font-size: 0.9rem; opacity: 0.8;">Spécialiste de l'énergie solaire en région PACA</p>
        </div>
    </footer>

    <script>
        // Header scroll effect
        window.addEventListener('scroll', function() {
            const header = document.querySelector('.logo-header');
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }
        });

        // Form submission v2 - Fixed CORS + Validation
        document.getElementById('devisForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            // Récupérer les valeurs
            const nom = document.getElementById('nom').value.trim();
            const email = document.getElementById('email').value.trim();
            const telephone = document.getElementById('telephone').value.replace(/\s/g, '');
            const codePostal = document.getElementById('codePostal').value.trim();
            const departement = document.getElementById('departement').value;
            const proprietaire = document.getElementById('proprietaire').value;

            // Validation nom (lettres uniquement, pas de chiffres)
            const nomRegex = /^[a-zA-ZÀ-ÿ\s\-']+$/;
            if (!nomRegex.test(nom)) {
                alert('❌ Nom invalide.\nLe nom ne doit contenir que des lettres (pas de chiffres).');
                return;
            }

            // Validation email
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                alert('❌ Email invalide.\nFormat attendu : exemple@domaine.com');
                return;
            }

            // Validation téléphone français (10 chiffres, commence par 0)
            const telRegex = /^0[1-9]\d{8}$/;
            if (!telRegex.test(telephone)) {
                alert('❌ Numéro de téléphone invalide.\nFormat attendu : 06 12 34 56 78 (10 chiffres)');
                return;
            }

            // Validation code postal PACA (13, 30, 83, 84)
            const cpRegex = /^(13|30|83|84)\d{3}$/;
            if (!cpRegex.test(codePostal)) {
                alert('❌ Code postal hors zone PACA.\nNous intervenons uniquement dans les départements 13, 30, 83 et 84.');
                return;
            }

            const formData = {
                nom: nom,
                email: email,
                telephone: telephone,
                codePostal: codePostal,
                departement: departement,
                source: 'devis-solaire-paca.fr',
                proprietaire: proprietaire,
                statusCall: 'NOUVEAU LEAD'
            };

            try {
                const response = await fetch('https://mycrm.solar/api/facebook-leads', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });

                const data = await response.json();

                if (response.ok) {
                    document.getElementById('successMessage').classList.add('show');
                    document.getElementById('devisForm').reset();

                    // Facebook Pixel - Lead Event
                    if (typeof fbq !== 'undefined') {
                        fbq('track', 'Lead');
                    }

                    // Google Ads - Conversion Event
                    if (typeof gtag !== 'undefined') {
                        gtag('event', 'conversion', {
                            'send_to': 'AW-17787585422/UiSwCLjgy_cbEI6H5KFC',
                            'value': 1.0,
                            'currency': 'AED'
                        });
                    }

                    setTimeout(() => {
                        document.getElementById('successMessage').classList.remove('show');
                    }, 5000);
                } else {
                    alert(data.error || 'Une erreur est survenue. Veuillez réessayer ou nous appeler directement.');
                }
            } catch (error) {
                alert('Une erreur est survenue. Veuillez réessayer ou nous appeler directement.');
            }
        });

        // FAQ Toggle
        document.querySelectorAll('.faq-item').forEach(item => {
            item.addEventListener('click', function() {
                this.classList.toggle('active');
            });
        });

        // Smooth scroll for CTA
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({behavior: 'smooth'});
                }
            });
        });
    </script>
</body>
</html>
